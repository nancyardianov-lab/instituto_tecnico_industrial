# ===================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO
# Instituto Técnico Industrial
# ===================================================================
# Copia este archivo como `.env` y completa los valores reales.
# NUNCA subas el archivo `.env` a GitHub (ya está excluido en .gitignore).
# ===================================================================

# --- BASE DE DATOS ---
# SQLite local (desarrollo):
DATABASE_URL="file:./db/custom.db"
# PostgreSQL (producción en Vercel/Railway/Neon):
# DATABASE_URL="postgresql://usuario:password@host:5432/nombre_db?schema=public"

# --- AUTENTICACIÓN JWT ---
# Genera uno aleatorio largo (ej: 64 caracteres). Puedes usar:
#   openssl rand -base64 48
JWT_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria-de-al-menos-64-caracteres"

# --- URL PÚBLICA (MUY IMPORTANTE PARA ENLACES DE ACTIVACIÓN) ---
# En desarrollo local:
NEXT_PUBLIC_URL="http://localhost:3000"
# En producción (Railway/Vercel), cambia a tu URL pública real, ej:
# NEXT_PUBLIC_URL="https://instituto-tecnico-industrial.up.railway.app"

# --- CORREO SMTP (Gmail) ---
# Para generar la contraseña de aplicación (16 caracteres):
# 1. Activa verificación en 2 pasos en tu cuenta Google
# 2. Ve a https://myaccount.google.com/apppasswords
# 3. Genera una contraseña de aplicación para "Correo"
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="465"
EMAIL_SECURE="true"
EMAIL_USER="tu-correo@gmail.com"
EMAIL_PASSWORD="tu-contraseña-de-aplicacion-de-16-caracteres"
EMAIL_FROM_NAME="Instituto Tecnico Industrial"
EMAIL_FROM_ADDRESS="tu-correo@gmail.com"
